@using System.Security.Cryptography.X509Certificates
@using MudBlazor.Utilities
@using System.Text.Json
@inherits LayoutComponentBase
@rendermode InteractiveAuto

@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IBrowserViewportService ViewportService

@implements IDisposable
@inject IDialogService DialogService

<MudThemeProvider @bind-IsDarkMode="@GlobalState.IsDarkMode"
    Theme="@CustomTheme"/>
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider />

<MudLayout>
    @if (!GlobalState.IsInitialized)
    {
        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16 text-center">
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">
                正在載入頁面...
            </MudText>
        </MudContainer>
    }
    else
    {
        @if (GlobalState.CurrentUser != null)
        {
            <MudAppBar Elevation="0" Color="Color.Inherit"
                Class="main-appbar px-2">

                <MudText Typo="Typo.h6" Class="ml-3"
                    Style="color: #4E342E; font-weight: 800;">
                    bento order
                </MudText>

                <MudSpacer />
                
                @* 電腦版 *@
                <div class="d-none d-md-flex align-center">
                    <MudText Typo="Typo.body2"
                        Class="mr-3 font-weight-bold"
                        Style="color: #4E342E; font-weight: 800;">
                        @GlobalState.CurrentUser.Realname
                    </MudText>

                    <MudButton Variant="Variant.Outlined"
                        Color="Color.Inherit"
                        OnClick="ShowMenu" Class="mr-4"
                        Style="color: #4E342E; font-weight: 800;"
                        StartIcon="@Icons.Material.Filled.RestaurantMenu">
                        菜單
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                        Color="Color.Inherit"
                        OnClick="HandleLogout"
                        Style="color: #4E342E; font-weight: 800;"
                        StartIcon="@Icons.Material.Filled.Logout">
                        登出
                    </MudButton>
                </div>

                @* 手機版 *@
                <div class="d-flex d-md-none align-center">
                    <MudAvatar Color="Color.Secondary"
                        Size="Size.Small" Style="font-size: 0.75rem;">
                        @(GlobalState.CurrentUser.Realname?.Substring(
                            0, 1
                        ) ?? "U")
                    </MudAvatar>

                    <MudIconButton
                        Icon="@Icons.Material.Filled.RestaurantMenu"
                        Color="Color.Inherit" OnClick="ShowMenu"
                        Class="d-md-none" />

                    <MudIconButton
                        Icon="@Icons.Material.Filled.Logout"
                        Color="Color.Inherit" OnClick="HandleLogout"
                        Class="d-md-none" />
                </div>
            </MudAppBar>

            @if (GlobalState.IsAdmin)
            {
                <MudDrawer Open="true" Variant="DrawerVariant.Persistent"
                    Elevation="0" ClipMode="DrawerClipMode.Always"
                    Width="180px">
                    <NavMenu />
                </MudDrawer>
            }
        }
        <MudMainContent>
            @Body
        </MudMainContent>
    }
</MudLayout>

<style>
    /* 讓 AppBar 有點奶油色半透明質感 */
    .main-appbar {
        background-color: rgba(247, 243, 238, 0.9) !important;
        backdrop-filter: blur(8px);
        border-bottom: 1px solid #E0D7C6;
    }

    .font-weight-bold {
        font-weight: 800;
    }

    /* 手機版按鈕微調 */
    @@media (max-width: 600px) {
        .mud-typography-h6 {
            font-size: 1rem !important;
        }
        
        /* 縮小手機版按鈕點擊區域，避免太擠 */
        .mud-button-root {
            padding: 4px 8px;
        }
    }
</style>

@code {
    private bool _drawerOpen = false;
    private bool _isMobile;

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    // 主題顏色配置
    private readonly MudTheme CustomTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            AppbarBackground = "#F7F3EE",
            AppbarText = "#4E342E",
            Background = "#F7F3EE",

            Primary = "#FF9800",
            Secondary = "#8D6E63",

            DrawerBackground = "#FFFEFA",
            DrawerText = "#4E342E",
            DrawerIcon = "#FF9800",

            Surface = "#FFFFFF",
            LinesDefault = "#E0D7C6",
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px",
            AppbarHeight = "64px"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] {
                    "Noto Sans TC", "微軟正黑體", "sans-serif"
                }
            }
        }
    };

    // 初始化
    protected override void OnInitialized()
    {
        base.OnInitialized();

        GlobalState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 確認是否初始化
            await GlobalState.EnsureInitialized(JS);

            // 取得相對路徑 (不含域名)
            var currentUrl =
                Navigation.ToBaseRelativePath(Navigation.Uri);
            
            // 沒登錄且不在首頁
            if (GlobalState.CurrentUser == null &&
                !string.IsNullOrEmpty(currentUrl))
            {
                Navigation.NavigateTo("/");
            }

            StateHasChanged();
        }
    }

    // 離開頁面
    public void Dispose()
    {
        GlobalState.OnChange -= StateHasChanged;
    }

    // 顯示菜單
    private async Task ShowMenu()
    {
        var options = new DialogOptions {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            NoHeader = true
        };

        var parameters =
            new DialogParameters<MenuDialog>
        {
            { x => x.ImageUrl, "/menu.jpg"}
        };

        await DialogService.ShowAsync<MenuDialog>(
            "本月菜單", parameters, options);
    }

    // 使用者登出
    private async Task HandleLogout()
    {
        // 清除使用者資訊
        GlobalState.CurrentUser = null;
        await JS.InvokeVoidAsync(
            "localStorage.removeItem", "user"
        );
        // 跳轉至登錄頁面
        Navigation.NavigateTo("/");
    }
}