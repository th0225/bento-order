@using System.Security.Cryptography.X509Certificates
@using MudBlazor.Utilities
@using System.Text.Json
@inherits LayoutComponentBase
@rendermode InteractiveAuto

@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation

@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@GlobalState.IsDarkMode"
    Theme="@CustomTheme"/>
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    @if (GlobalState.CurrentUser != null)
    {
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudText Typo="Typo.h6">bento order</MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Class="mr-4">
                @GlobalState.CurrentUser.Username
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                OnClick="HandleLogout" StartIcon="@Icons.Material.Filled.Logout">
                登出
            </MudButton>
            <MudIconButton
                Icon="@(GlobalState.IsDarkMode ? Icons.Material.Filled.LightMode :
                    Icons.Material.Filled.DarkMode)"
                Color="Color.Inherit"
                OnClick="@ToggleDarkMode" />
        </MudAppBar>

        <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2"
            ClipMode="DrawerClipMode.Always" Style="width: 180px;">
            <NavMenu />
        </MudDrawer>
    }

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    // 主題顏色配置
    private readonly MudTheme CustomTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Orange.Lighten1,
            Secondary = Colors.Pink.Lighten4,
            @* AppbarBackground = Colors.Orange.Lighten1,
            Background = Colors.Gray.Lighten3, *@
        },
        PaletteDark = new PaletteDark()
        {
            Primary = Colors.Orange.Darken1,
            Secondary = Colors.Pink.Accent1,
            @* AppbarBackground = Colors.Orange.Darken1, *@
            @* Background = "#121212", *@
        }
    };

    // 初始化
    protected override void OnInitialized()
    {
        base.OnInitialized();

        GlobalState.OnChange += StateHasChanged;
    }

    // 離開頁面
    public void Dispose()
    {
        GlobalState.OnChange -= StateHasChanged;
    }

    // 頁面渲染完成後，從local storage取得資料
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 確認是否初始化
            await GlobalState.EnsureInitialized(JS);
            StateHasChanged();
        }
    }

    // 切換深色模式
    private async Task ToggleDarkMode()
    {
        bool newMode = !GlobalState.IsDarkMode;
        GlobalState.SetDarkMode(newMode);
        await JS.InvokeVoidAsync(
            "localStorage.setItem",
            "darkMode", newMode.ToString()
        );
    }

    // 使用者登出
    private async Task HandleLogout()
    {
        // 清除使用者資訊
        GlobalState.CurrentUser = null;
        await JS.InvokeVoidAsync(
            "localStorage.removeItem", "user"
        );
        // 跳轉至登錄頁面
        Navigation.NavigateTo("/");
    }
}