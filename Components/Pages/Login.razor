@page "/"
@page "/login"

@using System.Text.Json
@using Microsoft.AspNetCore.Identity.Data
@using bento_order.Data
@using bento_order.Models
@using bento_order.Services

@inject BentoDbService BentoDbService
@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Style="height: 80vh;"
    Class="d-flex align-center justify-center">
    <MudPaper Elevation="4" Class="login-card">
        <MudForm OnEnterPressed="@(() => HandleLogin())">

            <div class="d-flex flex-column align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Restaurant" 
                        Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h5" Align="Align.Center"
                    GutterBottom="true" Class="longin-title">
                    Bento Order System
                </MudText>
            </div>
            
            <MudTextField @bind-Value="_username" Label="使用者帳號"
                Variant="Variant.Outlined" Class="mt-4"
                Immediate />
            <MudTextField @bind-Value="_password" Label="密碼"
                Variant="Variant.Outlined" InputType="@_passwordInput"
                Class="mt-4" Adornment="Adornment.End"
                Immediate AdornmentIcon="@_passwordInputIcon"
                OnAdornmentClick="TogglePasswordVisibility" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">
                    @_errorMessage
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                FullWidth="true" Size="Size.Large"
                Class="mt-6 py-3 rounded-lg"
                ButtonType="ButtonType.Submit" OnClick="HandleLogin">
                登入
            </MudButton>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private string _username = "";
    private string _password = "";
    private string _errorMessage = "";

    // 密碼可見性切換
    private bool _isShowPassword;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    // 登錄系統
    private async Task HandleLogin()
    {
        // 使用者登錄
        var user = await BentoDbService.LoginAsync(_username, _password);
        if (user != null)
        {
            // 序列化使用者資訊儲存至瀏覽器
            UserSession userSession = new()
            {
                Id = user.Id,
                Username = user.Username,
                Realname = user.RealName,
                Role = user.Role,
                Expiry = DateTime.Now.AddDays(7)
            };
            string userJson = JsonSerializer.Serialize(userSession);
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "user", userJson
            );

            // 儲存登入者資訊
            GlobalState.CurrentUser = userSession;

            if (GlobalState.IsAdmin)
            {
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                // 跳轉至首頁
                Navigation.NavigateTo("/home");
            }
        }
        else
        {
            _errorMessage = "帳號密碼有誤";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 確認是否初始化
            await GlobalState.EnsureInitialized(JS);

            if (GlobalState.CurrentUser == null)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                if (GlobalState.IsAdmin)
                {
                    Navigation.NavigateTo("/admin/users");
                }
                else
                {
                    Navigation.NavigateTo("/home");
                }
            }
        }
    }

    // 切換密碼是否可見
    void TogglePasswordVisibility()
    {
        if (_isShowPassword)
        {
            _isShowPassword = false;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _isShowPassword = true;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }
}