@page "/admin/stats"
@using bento_order.Services

@inject BentoDbService BentoDbService
@inject GlobalState GlobalState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-2">
    <MudPaper Class="pa-4 mb-2" Style="background-color: #f8f9fa;">
        <MudDatePicker Label="選擇日期" Date="_selectedDate"
                    PickerVariant="PickerVariant.Dialog"
                    DateChanged="OnDateChanged"
                    Color="Color.Primary" />
    </MudPaper>

    @if (_stats == null)
    {
        <MudProgressCircular Color="Color.Default" Indeterminate="true" />
    }
    else if (_stats.Count == 0)
    {
        <MudText>該日期尚無任何訂餐紀錄</MudText>
    }
    else
    {
        <MudTable Items="_stats" Breakpoint="Breakpoint.Sm" Elevation="2"
            Hover Dense Style="background-color: #f8f9fa;">
            <HeaderContent>
                <MudTh>餐點名稱</MudTh>
                <MudTh>數量</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="餐點">@context.MealName</MudTd>
                <MudTd DataLabel="數量">
                    <MudText Typo="Typo.h6">@context.Count</MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudText Typo="Typo.h5" Class="mb-4 mt-6">週期總量結算</MudText>
    <MudPaper Class="pa-4" Style="background-color: #f8f9fa;">
        <MudGrid >
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="開始日期" @bind-Date="_periodStart" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="結束日期" @bind-Date="_periodEnd" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                    StartIcon="@Icons.Material.Filled.Calculate"
                    FullWidth OnClick="CalculateTotal">
                    計算總數
                </MudButton>
            </MudItem>
        </MudGrid>
        @if (_totalOrder.HasValue)
        {
            <div class="mt-6 d-flex justify-center align-center">
                <MudPaper Class="pa-4 d-flex align-center"
                    Style="border: 2px dashed #666;">
                    <MudIcon Icon="@Icons.Material.Filled.Restaurant"
                        Color="Color.Dark" Size="Size.Large" Class="mr-3" />
                    <div>
                        <MudText Typo="Typo.subtitle1">
                            指定期間總計
                        </MudText>
                        <MudText Typo="Typo.h3" Color="Color.Primary">
                            <b>@_totalOrder</b>
                        </MudText>
                    </div>
                </MudPaper>
            </div>
        }
    </MudPaper>
</MudContainer>

@code {
    private DateTime? _selectedDate = DateTime.Today;
    private List<OrderCount>? _stats;
    private DateTime? _periodStart;
    private DateTime? _periodEnd;
    private int? _totalOrder;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        var now = DateTime.Today;
        _periodStart = new DateTime(now.Year, now.Month, 26)
            .AddMonths(-1);
        _periodEnd = new DateTime(now.Year, now.Month, 25);
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        await LoadStats();
        await CalculateTotal();
        StateHasChanged();
    }

    private async Task OnDateChanged(DateTime? newDate)
    {
        _selectedDate = newDate;
        await LoadStats();
    }

    private async Task LoadStats()
    {
        if (_selectedDate.HasValue)
        {
            _stats = await BentoDbService.GetDailyStatsAsync(
                _selectedDate.Value
            );
            StateHasChanged();
        }
    }

    private async Task CalculateTotal()
    {
        if (_periodStart.HasValue && _periodEnd.HasValue)
        {
            _totalOrder = await BentoDbService.GetPeriodTotalCountAsync(
                _periodStart.Value, _periodEnd.Value
            );
        }
    }
}