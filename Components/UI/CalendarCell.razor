@using bento_order.Services

@inject BentoDbService BentoDbService
@inject IMealProvider MealProvider
@inject ISnackbar Snackbar
@inject GlobalState GlobalState

<div class="cell-wrapper @(IsLocked() ? "cell-locked" : IsWeekend ? "weekend" : "weekday") shadow-soft">
    <div class="cell-header">
        <span class="day-num">@Date.Day</span>
        @if (IsLocked())
        {
            <div class="lock-overlay">
                <MudIcon Icon="@Icons.Material.Filled.LockClock"
                    Size="Size.Small" />
            </div>
        }
        @if (IsToday)
        {
            <div class="today-tag">TODAY</div>
        }
    </div>

    <div class="@(IsWeekend ? "rest-mode" : "cell-body")">
        <div class="meal-section">
            <div class="section-label">餐點1</div>
            <div class="select-group">
                <MudSelect T="string" Placeholder="餐點" Dense Clearable
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-2" Disabled="@IsLocked()"
                    Value="@(Order!.BentoItem!.Name ?? string.Empty)"
                    ValueChanged="@((string val) => 
                        OnMealChanged(val, "normal"))">
                    @foreach (var type in MealProvider.GetMealTypes())
                    {
                        <MudSelectItem Value="@type" />
                    }
                </MudSelect>
                @* <MudButton Variant="Variant.Outlined" Size="Size.Small"
                    Class="rice-cycle-btn"
                    OnClick="@(() => CycleRiceOptions("normal"))">
                    @GetRiceOptions("normal")
                </MudButton> *@
            </div>
        </div>

        <div class="meal-section">
            <div class="section-label">餐點2</div>
            <div class="select-group">
                <MudSelect T="string" Placeholder="餐點" Dense Clearable
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-2" Disabled="@IsLocked()"
                    Value="@(Order!.AdditionalBentoItem!.Name ?? string.Empty)"
                    ValueChanged="@((string val) => 
                        OnMealChanged(val, "add"))">
                    @foreach (var type in MealProvider.GetMealTypes())
                    {
                        <MudSelectItem Value="@type" />
                    }
                </MudSelect>
                @* <MudButton Variant="Variant.Outlined" Size="Size.Small"
                    Class="rice-cycle-btn"
                    OnClick="@(() => CycleRiceOptions(""))">
                    @GetRiceOptions("")
                </MudButton> *@
            </div>
        </div>
    </div>
</div>

<style>
    .cell-wrapper {
        min-height: 160px;
        display: flex;
        flex-direction: column;
        padding: 8px;
        border-radius: 16px;
        transition: transform 0.2s;
        background-color: #FFFFFF;
        box-shadow: 0 4px 12px rgba(93, 64, 55, 0.06); 
        border: 1px solid #EAE4DD;
    }
    /* 滑鼠移入格子的效果 */
    .cell-wrapper:hover { 
        border-color: #FFA726;
        box-shadow: 0 8px 20px rgba(255, 152, 0, 0.12);
        border-color: var(--mud-palette-primary);
    }
    .cell-locked {
        background-color: #f5f5f5; /* 灰色背景 */
        pointer-events: none;      /* 確保從 CSS 層級也無法點擊 */
        opacity: 0.7;
    }
    .lock-overlay {
        font-size: 10px;
        color: #d32f2f;
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 4px;
    }
    
    .weekday {
        background-color: #FFFFFF;
    }
    .weekend {
        background-color: #DBD5CF; 
        border-style: dashed;
    }

    .cell-header {
        display: flex; justify-content: space-between; align-items: center;
    }
    .day-num {
        font-weight: bold; color: var(--mud-palette-text-primary);
    }
    .today-tag { 
        font-size: 0.65rem; 
        background-color: #FFE0B2; /* 淺橘色 */
        color: #E65100; /* 深橘色文字 */
        padding: 1px 8px; 
        border-radius: 4px; 
        font-weight: 800;
    }

    .meal-section {
        margin-top: 4px;
    }
    .section-label { 
        font-size: 0.65rem; 
        color: #8D6E63; /* 改用褐色標籤，視覺更穩重 */
        font-weight: bold;
    }
    
    .select-group {
        display: flex; gap: 4px;
    }
    .flex-grow-2 {
        flex: 2;
    }
    .flex-grow-1 {
        flex: 1;
    }

    .rest-mode { 
        flex: 1; display: flex; flex-direction: column; 
        align-items: center; justify-content: center; color: #BDBDBD; 
    }

    /* 隱藏 MudSelect 預設底線顏色，讓介面更乾淨 */
    ::deep .mud-input > input.mud-input-root {
        font-size: 0.75rem !important;
    }

    .rice-cycle-btn {
        min-width: 32px !important;
        height: 32px !important;
        padding: 0 !important;
        border-radius: 8px !important;
        border: 1px solid #E0D7C6 !important;
        color: #5D4037 !important;
        font-weight: 800 !important;
    }
    
    .rice-cycle-btn:hover {
        background-color: #FFF3E0 !important;
        border-color: #FF9800 !important;
    }
</style>

@code {
    [Parameter]
    [EditorRequired]
    public DateTime Date { get; set; }

    [Parameter]
    public Order? Order { get; set; } = new();

    private Order _internalOrder = new();
    private CancellationTokenSource? _cts;
    private bool IsToday => Date.Date == DateTime.Today;
    private bool IsWeekend => 
        Date.DayOfWeek == DayOfWeek.Saturday ||
        Date.DayOfWeek == DayOfWeek.Sunday;

    private MealProvider mealProvider = new();
    // "普", "多", "少", "無"
    private List<string> _riceOptions = [];
    // 0, 1, 2, 3
    private List<int> _riceOptionsIndex = [0, 0];

    // 初始化
    protected override void OnInitialized()
    {
        base.OnInitialized();
        _riceOptions = mealProvider.GetMealOptions();

        if (Order == null)
        {
            Order = new Order
            {
                OrderDate = DateTime.Now.Date,
                BentoItem = new BentoItem
                {
                    Name = string.Empty, Option = "正"
                },
                AdditionalBentoItem = new BentoItem
                {
                    Name = string.Empty, Option = "正"
                }
            };
        }
        else
        {
            Order.BentoItem ??= new BentoItem
            {
                Name = string.Empty, Option = "正"
            };
            Order.AdditionalBentoItem ??= new BentoItem
            {
                Name = string.Empty, Option = "正"
            };
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (Order != null)
        {
            _internalOrder = new()
            {
                Id = Order.Id,
                UserId = Order.UserId,
                OrderDate = Date,
                BentoItem = Order.BentoItem ?? new() {
                    Name = string.Empty, Option = "正"
                },
                AdditionalBentoItem = Order.AdditionalBentoItem ??
                    new () {
                    Name = string.Empty, Option = "正"
                }
            };
        }
        else
        {
            _internalOrder = new()
            {
                OrderDate = Date,
                BentoItem = new () {
                    Name = string.Empty, Option = "正"
                },
                AdditionalBentoItem = new() {
                    Name = string.Empty, Option = "正"
                }
            };
        }
    }

    // 循環按鈕
    private async Task CycleRiceOptions(string target)
    {
        if (target == "normal")
        {
            _riceOptionsIndex[0] = 
                (_riceOptionsIndex[0] + 1) % _riceOptions.Count;
        }
        else
        {
            _riceOptionsIndex[1] = 
                (_riceOptionsIndex[1] + 1) % _riceOptions.Count;
        }

        await TriggerAutoSave();
    }

    private string GetRiceOptions(string target)
    {
        if (target == "normal")
        {
            return _riceOptions[_riceOptionsIndex[0]];
        }
        else
        {
            return _riceOptions[_riceOptionsIndex[1]];
        }
    }

    private async Task OnMealChanged(string value, string type)
    {
        _internalOrder.UserId = GlobalState.IsAdmin ? 
            GlobalState.FakeId : GlobalState.CurrentUser!.Id;
        _internalOrder.OrderDate = Date;

        if (type == "normal")
        {
            _internalOrder.BentoItem!.Name = value;
            _internalOrder.BentoItem!.Option =
                _riceOptions[_riceOptionsIndex[0]];
        }
        else
        {
            _internalOrder.BentoItem!.Name = value;
            _internalOrder.BentoItem!.Option =
                _riceOptions[_riceOptionsIndex[1]];
        }

        await TriggerAutoSave();
    }

    private async Task TriggerAutoSave()
    {
        _cts?.Cancel();
        _cts = new();

        try
        {
            await Task.Delay(500, _cts.Token);
            await BentoDbService.UpsertOrderAsync(
                _internalOrder, GlobalState.IsAdmin);

            Snackbar.Add("資料已同步", Severity.Info);

            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) {}
    }

    // 鎖定餐點選擇
    private bool IsLocked()
    {
        var now = DateTime.Now;
        var today = now.Date;
        var orderDate = Date;

        if (GlobalState.IsAdmin)
        {
            return false;
        }

        if (orderDate == today)
        {
            return now.Hour >= 9 && now.Minute >= 1;
        }

        if (orderDate < today)
        {
            return true;
        }

        return false;
    }
}