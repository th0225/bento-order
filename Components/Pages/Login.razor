@page "/"
@page "/login"
@attribute [AllowAnonymous]

@using System.Text.Json
@using bento_order.Models

@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Style="height: 80vh;"
    Class="d-flex align-center justify-center">
    <MudPaper Elevation="4" Class="login-card">
        <MudForm OnEnterPressed="@(() => HandleLogin())">

            <div class="d-flex flex-column align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Restaurant" 
                        Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h5" Align="Align.Center"
                    GutterBottom="true" Class="longin-title">
                    Bento Order System
                </MudText>
            </div>
            
            <MudTextField @bind-Value="_username" Label="使用者帳號"
                Variant="Variant.Outlined" Class="mt-4"
                Immediate />
            <MudTextField @bind-Value="_password" Label="密碼"
                Variant="Variant.Outlined" InputType="@_passwordInput"
                Class="mt-4" Adornment="Adornment.End"
                Immediate AdornmentIcon="@_passwordInputIcon"
                OnAdornmentClick="TogglePasswordVisibility" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">
                    @_errorMessage
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                FullWidth="true" Size="Size.Large"
                Class="mt-6 py-3 rounded-lg"
                ButtonType="ButtonType.Button" OnClick="HandleLogin"
                Disabled="@_isLoggingIn">
                @if (_isLoggingIn)
                {
                    <MudProgressCircular Size="Size.Small"
                        Indeterminate="true" Class="mr-2" />
                    <span>登入中...</span>
                }
                else
                {
                    <span>登入</span>
                }
            </MudButton>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private string _username = "";
    private string _password = "";
    private string _errorMessage = "";
    private bool _isLoggingIn = false;

    // 密碼可見性切換
    private bool _isShowPassword;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    // 登錄系統
    private async Task HandleLogin()
    {
        if (_isLoggingIn)
        {
            return;
        }

        _isLoggingIn = true;
        _errorMessage = string.Empty;

        try
        {
            var authResultJson = await JS.InvokeAsync<string>(
                "bentoAuth.login",
                _username,
                _password
            );

            var authResult = JsonSerializer.Deserialize<AuthLoginResult>(
                authResultJson,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }
            );

            if (authResult?.Success == true && authResult.User != null)
            {
                // 儲存登入者資訊
                GlobalState.CurrentUser = authResult.User;

                if (GlobalState.IsAdmin)
                {
                    Navigation.NavigateTo("/admin/users", forceLoad: true);
                }
                else
                {
                    // 跳轉至首頁
                    Navigation.NavigateTo("/home", forceLoad: true);
                }
            }
            else
            {
                _errorMessage = authResult?.ErrorMessage ?? "帳號密碼有誤";
            }
        }
        catch
        {
            _errorMessage = "登入失敗，請稍後再試";
        }
        finally
        {
            _isLoggingIn = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 確認是否初始化
            await GlobalState.EnsureInitialized(JS);

            if (GlobalState.CurrentUser == null)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                if (GlobalState.IsAdmin)
                {
                    Navigation.NavigateTo("/admin/users");
                }
                else
                {
                    Navigation.NavigateTo("/home");
                }
            }
        }
    }

    // 切換密碼是否可見
    void TogglePasswordVisibility()
    {
        if (_isShowPassword)
        {
            _isShowPassword = false;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _isShowPassword = true;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    private sealed class AuthLoginResult
    {
        public bool Success { get; set; }
        public string ErrorMessage { get; set; } = string.Empty;
        public UserSession? User { get; set; }
    }
}
