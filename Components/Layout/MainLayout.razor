@using System.Security.Cryptography.X509Certificates
@using MudBlazor.Utilities
@using System.Text.Json
@inherits LayoutComponentBase
@rendermode InteractiveAuto

@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation

@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@GlobalState.IsDarkMode"
    Theme="@CustomTheme"/>
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider />

<MudLayout>
    @if (GlobalState.CurrentUser != null)
    {
        <MudAppBar Elevation="0" Color="Color.Inherit" Class="main-appbar">
            <MudText Typo="Typo.h6" Class="ml-3"
                Style="color: #4E342E; font-weight: 800;">
                bento order
            </MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Class="mr-4"
                Style="color: #4E342E; font-weight: 800;">
                @GlobalState.CurrentUser.Username
            </MudText>
            <MudText Typo="Typo.body2" Class="mr-4"
                Style="color: #4E342E; font-weight: 800;">
                @GlobalState.CurrentUser.Realname
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                OnClick="HandleLogout"
                Style="color: #4E342E; font-weight: 800;"
                StartIcon="@Icons.Material.Filled.Logout">
                登出
            </MudButton>
            <MudIconButton
                Icon="@(GlobalState.IsDarkMode ? Icons.Material.Filled.LightMode :
                    Icons.Material.Filled.DarkMode)"
                Color="Color.Inherit" hidden
                OnClick="@ToggleDarkMode" />
        </MudAppBar>

        @if (GlobalState.IsAdmin)
        {
            <MudDrawer Open="true" Variant="DrawerVariant.Persistent"
                Elevation="0" ClipMode="DrawerClipMode.Always"
                Style="width: 180px;">
                <NavMenu />
            </MudDrawer>
        }
    }

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    // 主題顏色配置
    private readonly MudTheme CustomTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            AppbarBackground = "#F7F3EE",
            AppbarText = "#4E342E",
            Background = "#F7F3EE",
            
            Primary = "#FF9800",
            Secondary = "#8D6E63",
            
            DrawerBackground = "#FFFEFA",
            DrawerText = "#4E342E",
            DrawerIcon = "#FF9800",

            Surface = "#FFFFFF",
            LinesDefault = "#E0D7C6",
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px",
            AppbarHeight = "64px"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] {
                    "Noto Sans TC", "微軟正黑體", "sans-serif"
                }
            }
        }
    };

    // 初始化
    protected override void OnInitialized()
    {
        base.OnInitialized();

        GlobalState.OnChange += StateHasChanged;
    }

    // 離開頁面
    public void Dispose()
    {
        GlobalState.OnChange -= StateHasChanged;
    }

    // 頁面渲染完成後，從local storage取得資料
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 確認是否初始化
            await GlobalState.EnsureInitialized(JS);
            StateHasChanged();
        }
    }

    // 切換深色模式
    private async Task ToggleDarkMode()
    {
        bool newMode = !GlobalState.IsDarkMode;
        GlobalState.SetDarkMode(newMode);
        await JS.InvokeVoidAsync(
            "localStorage.setItem",
            "darkMode", newMode.ToString()
        );
    }

    // 使用者登出
    private async Task HandleLogout()
    {
        // 清除使用者資訊
        GlobalState.CurrentUser = null;
        await JS.InvokeVoidAsync(
            "localStorage.removeItem", "user"
        );
        // 跳轉至登錄頁面
        Navigation.NavigateTo("/");
    }
}