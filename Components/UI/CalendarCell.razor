@inject IMealProvider MealProvider

<div class="cell-wrapper @(IsWeekend ? "weekend" : "weekday") shadow-soft">
    <div class="cell-header">
        <span class="day-num">@Date.Day</span>
        @if (IsToday)
        {
            <div class="today-tag">TODAY</div>
        }
    </div>

    <div class="@(IsWeekend ? "rest-mode" : "cell-body")">
        <div class="meal-section">
            <div class="section-label">餐點1</div>
            <div class="select-group">
                <MudSelect T="string" Placeholder="餐點" Dense="true"
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-2">
                    @foreach (var type in MealProvider.GetMealTypes())
                    {
                        <MudSelectItem Value="@type" />
                    }
                </MudSelect>
                <MudSelect T="string" Placeholder="飯量" Dense="true"
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-1">
                    @foreach (var opt in MealProvider.GetMealOptions())
                    {
                        <MudSelectItem Value="@opt" />
                    }
                </MudSelect>
            </div>
        </div>

        <div class="meal-section">
            <div class="section-label">餐點2</div>
            <div class="select-group">
                <MudSelect T="string" Placeholder="餐點" Dense="true"
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-2">
                    @foreach (var type in MealProvider.GetMealTypes())
                    {
                        <MudSelectItem Value="@type" />
                    }
                </MudSelect>
                <MudSelect T="string" Placeholder="飯量" Dense="true"
                    Variant="Variant.Text" Margin="Margin.Dense"
                    Class="flex-grow-1">
                    @foreach (var opt in MealProvider.GetMealOptions())
                    {
                        <MudSelectItem Value="@opt" />
                    }
                </MudSelect>
            </div>
        </div>
    </div>
</div>

<style>
    .cell-wrapper {
        min-height: 160px;
        display: flex;
        flex-direction: column;
        padding: 8px;
        border-radius: 16px;
        transition: transform 0.2s;
        background-color: #FFFFFF;
        box-shadow: 0 4px 12px rgba(93, 64, 55, 0.06); 
        border: 1px solid #EAE4DD;
    }
    /* 滑鼠移入格子的效果 */
    .cell-wrapper:hover { 
        border-color: #FFA726;
        box-shadow: 0 8px 20px rgba(255, 152, 0, 0.12);
        border-color: var(--mud-palette-primary);
    }
    
    .weekday {
        background-color: #FFFFFF;
    }
    .weekend {
        background-color: #DBD5CF; 
        border-style: dashed;
    }

    .cell-header {
        display: flex; justify-content: space-between; align-items: center;
    }
    .day-num {
        font-weight: bold; color: var(--mud-palette-text-primary);
    }
    .today-tag { 
        font-size: 0.65rem; 
        background-color: #FFE0B2; /* 淺橘色 */
        color: #E65100; /* 深橘色文字 */
        padding: 1px 8px; 
        border-radius: 4px; 
        font-weight: 800;
    }

    .meal-section {
        margin-top: 4px;
    }
    .section-label { 
        font-size: 0.65rem; 
        color: #8D6E63; /* 改用褐色標籤，視覺更穩重 */
        font-weight: bold;
    }
    
    .select-group {
        display: flex; gap: 4px;
    }
    .flex-grow-2 {
        flex: 2;
    }
    .flex-grow-1 {
        flex: 1;
    }

    .rest-mode { 
        flex: 1; display: flex; flex-direction: column; 
        align-items: center; justify-content: center; color: #BDBDBD; 
    }

    /* 隱藏 MudSelect 預設底線顏色，讓介面更乾淨 */
    ::deep .mud-input > input.mud-input-root {
        font-size: 0.75rem !important;
    }
</style>

@code {
    [Parameter]
    public DateTime Date { get; set; }

    private bool IsToday => Date.Date == DateTime.Today;
    private bool IsWeekend => 
        Date.DayOfWeek == DayOfWeek.Saturday ||
        Date.DayOfWeek == DayOfWeek.Sunday;

    private string GetCellClass() => IsWeekend ? "cell-weekend" : "";
}