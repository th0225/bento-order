@page "/admin/daily-manager"
@using bento_order.Services

@inject BentoDbService BentoDbService
@inject GlobalState GlobalState
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-2">
    <MudPaper Class="pa-4 mb-2" Style="background-color: #f8f9fa;">
        <MudDatePicker Label="選擇日期" Date="_selectedDate"
            PickerVariant="PickerVariant.Dialog"
            DateChanged="OnDateChanged"
            Color="Color.Primary" />
    </MudPaper>

    <MudTable Items="_userOrders" Hover Dense FixedHeader Height="600px"
        Style="background-color: #f8f9fa;">
        <HeaderContent>
            <MudTh>姓名</MudTh>
            <MudTh>狀態</MudTh>
            <MudTh>餐點 1</MudTh>
            <MudTh>餐點 2</MudTh>
            <MudTh>操作</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="姓名">@context.Username</MudTd>
            <MudTd DataLabel="狀態">
                @if (context.HasOrdered)
                {
                    <MudChip T="string" Color="Color.Success"
                        Size="Size.Small">
                        已訂
                    </MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Error"
                        Size="Size.Small">
                        未訂
                    </MudChip>
                }
            </MudTd>
            <MudTd>@context.OrderData.BentoItem?.Name</MudTd>
            <MudTd>@context.OrderData.AdditionalBentoItem?.Name</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                    Color="Color.Primary"
                    OnClick="@(() => EditUserOrder(context, context.UserId))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private DateTime? _selectedDate = DateTime.Today;
    private List<UserOrderDisplay> _userOrders = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    
    private async Task OnDateChanged(DateTime? newDate)
    {
        _selectedDate = newDate;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (_selectedDate.HasValue)
        {
            _userOrders = await BentoDbService.GetDailyDetailAsync(
                _selectedDate.Value
            );
            StateHasChanged();
        };
    }

    private async Task EditUserOrder(UserOrderDisplay item, int userId)
    {
        GlobalState.FakeId = userId;
        Order? order = new();
        if (_selectedDate.HasValue)
        {
            order = await BentoDbService.GetOrderByUserAsync(
              userId, _selectedDate.Value
            );

            if (order == null)
            {
                order = new();
                order.Id = userId;
                order.OrderDate = _selectedDate.Value;

                BentoItem bentoItem = new()
                {
                    Name = string.Empty
                };
                BentoItem addBentoItem = new()
                {
                    Name = string.Empty
                };

                order.BentoItem = bentoItem;
                order.AdditionalBentoItem = addBentoItem;
            }
        }

        var parameters =
            new DialogParameters<CalendarDialog>
        {
            { x => x.Title, "修改餐點" },
            { x => x.Order, order }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small
        };

        var dialog =
            await DialogService.ShowAsync<CalendarDialog>(
            "", parameters, options
        );
        
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            await LoadData();
        }
    }
}