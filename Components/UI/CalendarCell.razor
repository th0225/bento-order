@inject IMealProvider MealProvider

<div class="cell-wrapper @GetCellClass()">
    <div class="cell-header">
        <span class="day-num">@Date.Day</span>
        @if (IsToday)
        {
            <div class="today-indicator">TODAY</div>
        }
    </div>

    <div class="cell-content">
        @if (!IsWeekend)
        {
            <div class="meal-group">
                <div class="group-label">餐點1</div>
                <div class="select-row">
                    <MudSelect T="string" Placeholder="餐點" Dense="true"
                        Variant="Variant.Text" Margin="Margin.Dense"
                        Class="meal-main">
                        @foreach (var type in MealProvider.GetMealTypes())
                        {
                            <MudSelectItem Value="@type" />
                        }
                    </MudSelect>
                    <MudSelect T="string" Placeholder="飯量" Dense="true"
                        Variant="Variant.Text" Margin="Margin.Dense"
                        Class="meal-sub">
                        @foreach (var opt in MealProvider.GetMealOptions())
                        {
                            <MudSelectItem Value="@opt" />
                        }
                    </MudSelect>
                </div>
            </div>

            <div class="meal-group">
                <div class="group-label">餐點2</div>
                <div class="select-row">
                    <MudSelect T="string" Placeholder="餐點" Dense="true"
                        Variant="Variant.Text" Margin="Margin.Dense"
                        Class="meal-main">
                        @foreach (var type in MealProvider.GetMealTypes())
                        {
                            <MudSelectItem Value="@type" />
                        }
                    </MudSelect>
                    <MudSelect T="string" Placeholder="飯量" Dense="true"
                        Variant="Variant.Text" Margin="Margin.Dense"
                        Class="meal-sub">
                        @foreach (var opt in MealProvider.GetMealOptions())
                        {
                            <MudSelectItem Value="@opt" />
                        }
                    </MudSelect>
                </div>
            </div>
        }
        else
        {
            <div class="weekend-placeholder">
                <MudIcon Icon="@Icons.Material.Filled.Coffee"
                    Size="Size.Small" Color="Color.Default" />
                <span class="mt-1">休息</span>
            </div>
        }
    </div>
</div>

<style>
    /* 元件外殼 */
    .cell-wrapper {
        min-height: 155px;
        padding: 6px;
        border-radius: 16px;
        background-color: #FFFDF6; /* 更柔和的奶油白 */
        border: 1.5px solid #F0EBE3;
        display: flex;
        flex-direction: column;
        transition: all 0.2s ease;
    }

    .cell-weekend {
        background-color: #F9F9F9;
        border: 1.5px dashed #E0E0E0;
    }

    /* 標題與日期 */
    .cell-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2px;
    }

    .day-num {
        font-weight: 800;
        color: #795548;
        font-size: 0.9rem;
    }

    .today-indicator {
        font-size: 0.6rem;
        background-color: #FFCC80;
        color: #E65100;
        padding: 0 6px;
        border-radius: 10px;
        font-weight: bold;
    }

    /* 內容佈局 */
    .cell-content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
    }

    .meal-group {
        display: flex;
        flex-direction: column;
    }

    .group-label {
        font-size: 0.6rem;
        color: #BCAA99;
        font-weight: bold;
        margin-bottom: -4px;
        margin-left: 2px;
    }

    .select-row {
        display: flex;
        gap: 4px;
    }

    .meal-main { flex: 62; }
    .meal-sub { flex: 38; }

    /* 假日占位符 */
    .weekend-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #BDBDBD;
        font-size: 0.75rem;
    }

    /* MudBlazor 樣式微調 (CSS 穿透) */
    ::deep .mud-input {
        font-size: 0.75rem !important;
        margin-top: 0 !important;
    }
    ::deep .mud-input > input.mud-input-root {
        padding: 4px 0 !important;
    }
    ::deep .mud-select .mud-select-input .mud-input-adornment {
        margin-inline-start: 0 !important;
    }
    /* 隱藏底線，讓介面更乾淨 */
    ::deep .mud-input-underline:before {
        border-bottom: 1px solid rgba(0,0,0,0.05) !important;
    }
</style>

@code {
    [Parameter]
    public DateTime Date { get; set; }

    private bool IsToday => Date.Date == DateTime.Today;
    private bool IsWeekend => 
        Date.DayOfWeek == DayOfWeek.Saturday ||
        Date.DayOfWeek == DayOfWeek.Sunday;

    private string GetCellClass() => IsWeekend ? "cell-weekend" : "";
}