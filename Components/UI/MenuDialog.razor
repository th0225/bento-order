<MudDialog Style="background-color: #FFFDF7; border-radius: 20px;">
    <DialogContent>
        <div class="d-flex justify-center">
            @if (string.IsNullOrEmpty(ImageUrl))
            {
                <MudAlert Severity="Severity.Info">
                    尚未上傳菜單
                </MudAlert>
            }
            else
            {
                <MudImage Src="@($"{ImageUrl}?v={DateTime.Now.Ticks}")"
                    Alt="本月菜單" Elevation="4" Class="rounded-lg"
                    Style="max-width: 100%; max-height: 80vh;
                        object-fit: contain;" />
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close"
            Variant="Variant.Text"
            Style="font-weight: 800; width: 100% height: 50px">
            關閉菜單
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string? ImageUrl { get; set; }

    private void Close() => MudDialog.Close();
}