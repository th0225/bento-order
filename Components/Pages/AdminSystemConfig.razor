@page "/admin/system-config"
@using bento_order.Services

@inject BentoDbService BentoDbService
@inject BentoReportService BentoReportService
@inject GlobalState GlobalState
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h5" GutterBottom="true">
        系統設定
    </MudText>

    <MudPaper Class="pa-4 mb-6" Style="background-color: #f8f9fa;">
        <MudTextField @bind-Value="@GlobalState.LineAccessToken"
            Label="LINE Access Token" Variant="Variant.Outlined"
            Margin="Margin.Dense"
            InputType="@(_isShowLineAccessToken ? 
                InputType.Text : InputType.Password)"
            Adornment="Adornment.End"
            AdornmentIcon="@(_isShowLineAccessToken ?
                Icons.Material.Filled.Visibility : 
                Icons.Material.Filled.VisibilityOff)"
            OnAdornmentClick="() => _isShowLineAccessToken = 
                !_isShowLineAccessToken" />

        <MudTextField @bind-Value="@GlobalState.LineId" Class="mt-4"
            Label="LINE 群組/聊天室 ID" Variant="Variant.Outlined"
            Margin="Margin.Dense"
            InputType="@(_isShowLineId ? InputType.Text : InputType.Password)"
            Adornment="Adornment.End"
            AdornmentIcon="@(_isShowLineId ?
                Icons.Material.Filled.Visibility : 
                Icons.Material.Filled.VisibilityOff)"
            OnAdornmentClick="() => _isShowLineId = !_isShowLineId" />
        
        <MudGrid Class="mt-4">
            <MudItem xs="12" sm="3">
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                    OnClick="SaveConfigAsync">
                    儲存設定
                </MudButton>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudButton Variant="Variant.Filled" Color="Color.Info"
                    OnClick="SendTestLineMessage" FullWidth
                    StartIcon="@Icons.Material.Filled.NotificationAdd">
                    手動發送Line統計
                </MudButton>
            </MudItem>
        </MudGrid>

    </MudPaper>
</MudContainer>

@code {
    private bool _isShowLineAccessToken = false;
    private bool _isShowLineId = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadConfigAsync();
    }

    private async Task SaveConfigAsync()
    {
        try
        {
            SystemConfig lineId = new()
            {
                Key = "LineId",
                Value = GlobalState.LineId ?? string.Empty
            };

            SystemConfig lineAccessToken = new()
            {
                Key = "LineAccessToken",
                Value = GlobalState.LineAccessToken ?? string.Empty
            };

            await BentoDbService.SaveConfigAsync(lineId);
            await BentoDbService.SaveConfigAsync(lineAccessToken);
            await LoadConfigAsync();
            Snackbar.Add("✅ 系統設定已成功儲存至資料庫", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"❌ 儲存失敗：{ex.Message}", Severity.Error);
        }
    }

    private async Task LoadConfigAsync()
    {
        List<SystemConfig> configs = await BentoDbService.GetConfigAsync();

        if (configs != null && configs.Any())
        {
            GlobalState.LineAccessToken = configs.FirstOrDefault(
                c => c.Key == "LineAccessToken"
            )?.Value ?? string.Empty;

            GlobalState.LineId = configs.FirstOrDefault(
                c => c.Key == "LineId"
            )?.Value ?? string.Empty;
        }
    }

    private async Task SendTestLineMessage()
    {
        try
        {
            await BentoReportService.ProcessAndSendReportAsync();
            Snackbar.Add(
                "✅ LINE 統計訊息已成功發送！", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"❌ 發送失敗：{ex.Message}", Severity.Error);
        }
    }
}