@page "/"
@page "/login"

@using System.Text.Json
@using bento_order.Data
@using bento_order.Models
@using bento_order.Services

@inject BentoDbService BentoDbService
@inject GlobalState GlobalState
@inject IJSRuntime JS
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Style="height: 80vh;"
    Class="d-flex align-center justify-center">
    <MudPaper Elevation="4" Class="pa-8"
        Style="width: 100%; ">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">
            Bento Order System
        </MudText>
        
        <MudTextField @bind-Value="_username" Label="使用者帳號"
            Variant="Variant.Outlined" Class="mt-4" />
        <MudTextField @bind-Value="_password" Label="密碼"
            Variant="Variant.Outlined" InputType="InputType.Password"
            Class="mt-4" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
            FullWidth="true" Size="Size.Large" Class="mt-6"
            OnClick="HandleLogin">
            登入
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private string _username = "";
    private string _password = "";
    private string _errorMessage = "";

    // 登錄系統
    private async Task HandleLogin()
    {
        // 使用者登錄
        var user = await BentoDbService.LoginAsync(_username, _password);
        if (user != null)
        {
            // 序列化使用者資訊儲存至瀏覽器
            UserSession userSession = new()
            {
                Id = user.Id,
                Username = user.Username,
                Role = user.Role
            };
            string userJson = JsonSerializer.Serialize(userSession);
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "user", userJson
            );

            // 儲存登入者資訊
            GlobalState.CurrentUser = userSession;

            // 跳轉至首頁
            Navigation.NavigateTo("/home");
        }
        else
        {
            _errorMessage = "帳號密碼有誤";
        }
    }
}